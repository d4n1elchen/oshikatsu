    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.14",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0"
  }
