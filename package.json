{
  "name": "oshikatsu",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "start:tui": "tsx src/index.tsx",
    "login:twitter": "tsx src/scripts/twitterLogin.ts",
    "extract:once": "tsx src/scripts/extractOnce.ts",
    "resolve:once": "tsx src/scripts/resolveOnce.ts",
    "reset": "tsx src/scripts/resetDb.ts",
    "reset:artists": "tsx src/scripts/resetDb.ts --artists",
    "reset:targets": "tsx src/scripts/resetDb.ts --watch_targets",
    "reset:raw": "tsx src/scripts/resetDb.ts --raw_items",
    "reset:venues": "tsx src/scripts/resetDb.ts --venues",
    "reset:venue-aliases": "tsx src/scripts/resetDb.ts --venue_aliases",
    "reset:extracted": "tsx src/scripts/resetDb.ts --extracted_events",
    "reset:links": "tsx src/scripts/resetDb.ts --extracted_links",
    "reset:normalized": "tsx src/scripts/resetDb.ts --normalized_events",
    "reset:normalized-sources": "tsx src/scripts/resetDb.ts --normalized_event_sources",
    "reset:decisions": "tsx src/scripts/resetDb.ts --resolution_decisions",
    "reset:runs": "tsx src/scripts/resetDb.ts --scheduler_runs",
    "reset:export-queue": "tsx src/scripts/resetDb.ts --export_queue",
    "reset:export-cursors": "tsx src/scripts/resetDb.ts --export_cursors",
    "reset:resolution": "tsx src/scripts/resetDb.ts --resolution",
    "reset:export": "tsx src/scripts/resetDb.ts --export",
    "reset:watchlist": "tsx src/scripts/resetDb.ts --watchlist",
    "reset:all": "tsx src/scripts/resetDb.ts --all",
    "reset:everything": "tsx src/scripts/resetDb.ts --everything",
    "start:backend": "tsx src/daemon.ts",
    "web:dev": "concurrently -k -n vite,server -c blue,magenta \"vite\" \"tsx watch src/web/server.ts\"",
    "web:build": "vite build",
    "web:start": "tsx src/web/server.ts",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx/esm --test src/**/__tests__/**/*.test.ts",
    "test": "npm run typecheck && npm run test:unit"
  },
