# Oshikatsu Configuration File
# This file overrides the default application settings.

scheduler:
  ingestionIntervalMinutes: 60      # how often to fetch new raw items from sources
  extractionIntervalMinutes: 5      # how often to run LLM extraction over unprocessed raw items
  resolutionIntervalMinutes: 2      # how often to resolve newly extracted events into normalized events
  exportIntervalMinutes: 5          # how often to push canonical events to registered consumers (Phase 5)

llm:
  provider: "ollama"
  host: "http://127.0.0.1:11434"
  model: "llama3"

twitter:
  maxTweetsPerSource: 50
  headless: true
  interTargetDelayMs: 3000           # delay between successive target fetches (with ±25% jitter); set to 0 to disable

paths:
  browserData: "./browser_data"
  database: "./data/oshikatsu.db"

# Event resolution thresholds (Phase 3). Tune these to be more or less
# aggressive about auto-merging duplicate events. Lower thresholds merge more;
# higher thresholds defer more to the review queue.
resolution:
  titleSimilarityThreshold: 0.6   # min title similarity for venue+time merges
  autoMergeScoreThreshold: 0.7    # aggregate score required to auto-merge
  needsReviewScoreThreshold: 0.25 # below auto-merge but above this → review queue
  candidateWindowHours: 48        # ± window for considering events the same

# Phase 5: downstream export. When enabled, the resolver enqueues canonical
# event changes into export_queue and the daemon registers an Export task
# that drives registered consumers.
export:
  enabled: false
  ical:
    enabled: false
    outputDir: "./data/ical"   # one <artist-id>.ics file per artist
    calendarPrefix: "Oshikatsu" # X-WR-CALNAME prefix; full name is "<prefix> — <artist name>"
